# Copy this file to `.env` and adjust as needed. NEVER commit your real .env.
# SauceDemo is a public demo app; these are its documented, public test credentials.

# Base URL of the system under test
BASE_URL=https://www.saucedemo.com

# Standard user (happy-path). SauceDemo publishes these on its login page.
SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# A user that is accepted at login but exhibits UI glitches — used for edge-case tests.
SAUCE_PROBLEM_USERNAME=problem_user

# A user that is rejected at login — used for negative-auth tests.
SAUCE_LOCKED_USERNAME=locked_out_user
